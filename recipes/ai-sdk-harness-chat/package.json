{
  "name": "ai-sdk-harness-chat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build -w @islo-labs/ai-sdk-sandbox && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --experimental-strip-types --test lib/**/*.test.ts",
    "probe:wss": "node scripts/probe-wss-share.mjs",
