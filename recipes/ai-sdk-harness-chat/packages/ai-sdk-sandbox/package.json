{
  "name": "@islo-labs/ai-sdk-sandbox",
  "version": "0.1.0",
  "description": "HarnessV1SandboxProvider for Islo sandboxes (AI SDK HarnessAgent)",
  "type": "module",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@islo-labs/sdk": "^0.0.30"
  },
  "peerDependencies": {
    "@ai-sdk/harness": "^1.0.33",
    "@ai-sdk/provider-utils": "^5.0.10"
  },
  "devDependencies": {
    "@ai-sdk/harness": "^1.0.33",
    "@ai-sdk/provider-utils": "^5.0.10",
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  }
}
