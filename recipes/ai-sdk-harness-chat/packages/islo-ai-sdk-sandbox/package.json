{
  "name": "@islo-labs/islo-ai-sdk-sandbox",
  "version": "0.1.0",
  "description": "Islo sandbox provider for the AI SDK HarnessAgent",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@islo-labs/sdk": "^0.0.31"
  },
  "peerDependencies": {
    "@ai-sdk/harness": "^1.0.0",
    "@ai-sdk/provider-utils": "^5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/harness": "^1.0.36",
    "@ai-sdk/provider-utils": "^5.0.11",
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islo-labs/recipes.git",
    "directory": "recipes/ai-sdk-harness-chat/packages/islo-ai-sdk-sandbox"
  },
  "homepage": "https://github.com/islo-labs/recipes/tree/main/recipes/ai-sdk-harness-chat/packages/islo-ai-sdk-sandbox",
  "bugs": {
    "url": "https://github.com/islo-labs/recipes/issues"
  },
  "keywords": [
    "islo",
    "ai-sdk",
    "harness",
    "sandbox",
    "codex"
  ]
}
